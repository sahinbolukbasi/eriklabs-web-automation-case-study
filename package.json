  "scripts": {
    "test": "npx cucumber-js",
    "test:smoke": "npx cucumber-js --profile smoke",
    "test:regression": "npx cucumber-js --profile regression",
    "test:negative": "npx cucumber-js --profile negative",
    "test:parallel": "npx cucumber-js --profile parallel",
    "test:tag": "npx cucumber-js --tags",
    "allure:generate": "npx allure-commandline generate allure-results --clean -o allure-report",
    "allure:open": "npx allure-commandline open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
